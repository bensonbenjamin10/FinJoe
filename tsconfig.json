{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@lib/*": ["lib/*"]
    }
  },
  "include": ["shared/**/*", "lib/**/*", "server/**/*", "worker/src/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist", "client"]
}

{
  "name": "finjoe",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx server/index.ts",
    "worker:dev": "tsx worker/src/index.ts",
    "worker:build": "cd worker && esbuild src/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "worker:start": "node worker/dist/index.js",

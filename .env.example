# FinJoe Environment Variables
# Use pg (TCP) driver. For Neon: pooled connection (host has -pooler). For Railway Postgres: reference the Postgres service's DATABASE_URL.
DATABASE_URL=postgresql://...
SESSION_SECRET=change-in-production

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional: for worker-only deployment
RAILWAY_SERVICE_NAME=finjoe-worker

# Cron: set CRON_SECRET; worker exposes /cron/weekly-insights, /cron/recurring-expenses, /cron/backfill-embeddings
CRON_SECRET=
# Cron service only: URL of the worker (e.g. https://finjoe-worker-xxx.up.railway.app). Required so cron hits the worker, not the frontend.
FINJOE_WORKER_URL=
# Optional: max expenses to embed per cron/startup run (default 500). Manual backfill has no limit.
# BACKFILL_EMBEDDINGS_MAX_PER_RUN=500

# Twilio webhook URL for signature validation (used when webhook runs in main server)
FINJOE_WEBHOOK_URL=https://finjoe.app/webhook/finjoe

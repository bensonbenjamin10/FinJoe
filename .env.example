# FinJoe Environment Variables
# Use pg (TCP) driver.
# Railway: DATABASE_URL=${{ pgvector.DATABASE_URL_PRIVATE }} (internal) for API/worker/cron.
# Local/dev: Use pooled connection string.
DATABASE_URL=postgresql://...
# Default: run Drizzle migrations before the server starts (skipped only if RUN_MIGRATIONS_ON_START=false).
# RUN_MIGRATIONS_ON_START=false

# Required when NODE_ENV=production (the server will refuse to start without it).
SESSION_SECRET=change-in-production

# Public browser URL for invite links (password setup). e.g. https://finjoe.app
PUBLIC_APP_URL=

# Resend (email)
RESEND_API_KEY=re_...
RESEND_FROM=FinJoe <notifications@yourdomain.com>

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Gemini
GEMINI_API_KEY=
# WhatsApp worker / fast turns (default gemini-2.5-flash in code)
GEMINI_MODEL=gemini-2.5-flash
# Dashboard analytics + CFO insights + cash predictions (default gemini-3.1-pro-preview in code)
GEMINI_ANALYSIS_MODEL=gemini-3.1-pro-preview

# Optional: for worker-only deployment
RAILWAY_SERVICE_NAME=finjoe-worker

# Cron: set CRON_SECRET; main app exposes /cron/weekly-insights, /cron/cfo-insight-snapshots, /cron/recurring-expenses, /cron/backfill-embeddings
CRON_SECRET=
# Cron service only: URL of worker/main app. Railway: use http://finjoe.railway.internal:8080 for internal.
FINJOE_WORKER_URL=
# Optional: max expenses to embed per cron/startup run (default 500). Manual backfill has no limit.
# BACKFILL_EMBEDDINGS_MAX_PER_RUN=500

# Twilio webhook URL for signature validation (used when webhook runs in main server)
FINJOE_WEBHOOK_URL=https://finjoe.app/webhook/finjoe

# --- S3-compatible backup (Railway bucket, etc.) — optional; see docs/runbooks/BACKUP_RESTORE.md
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=auto
# AWS_ENDPOINT_URL=https://storage.railway.app
# AWS_S3_BUCKET_NAME=
# BACKUP_S3_PREFIX=backups
# BACKUP_SKIP_MEDIA=0
# Cron service: set FINJOE_APP_URL=https://finjoe.app so run-all-cron.mjs can call GET /cron/backup on the main app (volume lives there)

# Zoho Books (India: accounts.zoho.in + zohoapis.in). OAuth callback must match ZOHO_REDIRECT_URI exactly.
# APP_BASE_URL optional; used after OAuth redirect (e.g. https://finjoe.app)
APP_BASE_URL=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=https://finjoe.app/api/integrations/zoho/oauth/callback
# Optional overrides (defaults: India endpoints)
# ZOHO_ACCOUNTS_BASE=https://accounts.zoho.in
# ZOHO_BOOKS_API_BASE=https://www.zohoapis.in/books/v3

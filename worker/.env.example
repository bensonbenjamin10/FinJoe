# FinJoe Worker - Environment Variables
# For Railway: Set these in Project → Variables (never commit secrets)
# For local dev: Copy to .env (gitignored)

DATABASE_URL=postgresql://...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FINJOE_WHATSAPP_FROM=whatsapp:+15558171150
TWILIO_SMS_FROM=+15558171150
RESEND_API_KEY=re_...
RESEND_FROM=FinJoe <notifications@yourdomain.com>
GEMINI_API_KEY=...
FINJOE_SERVICE_SECRET=...
MEDPGBUDDY_API_URL=https://your-app.railway.app
PORT=5001

# Twilio webhook URL for signature validation. When using the main server proxy, set to the public URL Twilio calls (e.g. https://finjoe.app/webhook/finjoe).
FINJOE_WEBHOOK_URL=https://finjoe.app/webhook/finjoe
